{
  "info": {
    "name": "Raízes do Nordeste API",
    "description": "Coleção MVP — fluxo auth, unidades, produtos, estoque, pedidos, pagamento, fidelidade e auditoria.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "pedidoId", "value": "1" },
    { "key": "transactionId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registro Cliente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Cliente Teste\",\n  \"email\": \"cliente@teste.com\",\n  \"senha\": \"123456\",\n  \"telefone\": \"81999999999\",\n  \"consentimentoLgpd\": true\n}"
            },
            "url": "{{baseUrl}}/auth/registro"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@teste.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Unidades",
      "item": [
        {
          "name": "Listar Unidades",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/unidades"
          }
        },
        {
          "name": "Criar Unidade",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Raízes Centro\",\n  \"endereco\": \"Rua A, 100\",\n  \"cidade\": \"Recife\",\n  \"estado\": \"PE\",\n  \"ativa\": true\n}"
            },
            "url": "{{baseUrl}}/unidades"
          }
        }
      ]
    },
    {
      "name": "Produtos",
      "item": [
        {
          "name": "Listar Produtos por Unidade",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/produtos?unidadeId=1",
              "host": ["{{baseUrl}}"],
              "path": ["produtos"],
              "query": [{ "key": "unidadeId", "value": "1" }]
            }
          }
        },
        {
          "name": "Criar Produto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Baião de Dois\",\n  \"descricao\": \"Prato típico\",\n  \"preco\": 25.90,\n  \"ativo\": true\n}"
            },
            "url": "{{baseUrl}}/produtos"
          }
        }
      ]
    },
    {
      "name": "Estoque",
      "item": [
        {
          "name": "Consultar Estoque",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/estoque?unidadeId=1",
              "host": ["{{baseUrl}}"],
              "path": ["estoque"],
              "query": [{ "key": "unidadeId", "value": "1" }]
            }
          }
        },
        {
          "name": "Entrada Estoque",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 1,\n  \"produtoId\": 1,\n  \"quantidade\": 50\n}"
            },
            "url": "{{baseUrl}}/estoque/entrada"
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Criar Pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('pedidoId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 1,\n  \"canalPedido\": \"WEB\",\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 2 }\n  ],\n  \"pontosResgatados\": 0\n}"
            },
            "url": "{{baseUrl}}/pedidos"
          }
        },
        {
          "name": "Listar Pedidos (filtro canalPedido)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/pedidos?canalPedido=WEB&status=AGUARDANDO_PAGAMENTO",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos"],
              "query": [
                { "key": "canalPedido", "value": "WEB" },
                { "key": "status", "value": "AGUARDANDO_PAGAMENTO" }
              ]
            }
          }
        },
        {
          "name": "Buscar Pedido por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/pedidos/{{pedidoId}}"
          }
        },
        {
          "name": "Cancelar Pedido",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/pedidos/{{pedidoId}}/cancelar"
          }
        },
        {
          "name": "Atualizar Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_PREPARO\"\n}"
            },
            "url": "{{baseUrl}}/pedidos/{{pedidoId}}/status"
          }
        }
      ]
    },
    {
      "name": "Pagamentos",
      "item": [
        {
          "name": "Solicitar Pagamento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('transactionId', pm.response.json().transactionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/pagamentos/solicitar/{{pedidoId}}"
          }
        },
        {
          "name": "Callback APROVADO",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\",\n  \"status\": \"APROVADO\"\n}"
            },
            "url": "{{baseUrl}}/pagamentos/callback"
          }
        },
        {
          "name": "Callback NEGADO",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\",\n  \"status\": \"NEGADO\"\n}"
            },
            "url": "{{baseUrl}}/pagamentos/callback"
          }
        }
      ]
    },
    {
      "name": "Fidelidade",
      "item": [
        {
          "name": "Consultar Saldo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/fidelidade/saldo"
          }
        },
        {
          "name": "Histórico",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/fidelidade/historico"
          }
        },
        {
          "name": "Resgatar Pontos",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pontos\": 50\n}"
            },
            "url": "{{baseUrl}}/fidelidade/resgate"
          }
        }
      ]
    },
    {
      "name": "Auditoria",
      "item": [
        {
          "name": "Listar Auditoria",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auditoria"
          }
        }
      ]
    }
  ]
}
